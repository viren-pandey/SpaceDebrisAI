# ── Backend ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require
NEON_AUTH_URL=https://your-project.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_JWKS_URL=https://your-project.neonauth.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
SPACETRACK_EMAIL=your_spacetrack_email@example.com
SPACETRACK_PASSWORD=your_spacetrack_password
USAGE_ADMIN_KEY=replace_with_long_random_admin_key
RATE_LIMIT_EXEMPT_IPS=127.0.0.1,::1
RATE_LIMIT_EXEMPT_EMAILS=admin@example.com
RATE_LIMIT_EXEMPT_API_KEYS=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
KEEPTRACK_API_KEY=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_admin_password
JWT_SECRET=replace_with_a_long_random_secret

# ── Frontend (must prefix with VITE_ for Vite) ────────────────
VITE_API_URL=https://your-backend-api.example.com
VITE_ADMIN_KEY=replace_with_secure_admin_key
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=replace_with_strong_admin_password

# ── Hugging Face Space Secrets ─────────────────────────────────
# Add these in HF Space > Settings > Repository secrets:
# DATABASE_URL, NEON_AUTH_URL, NEON_JWKS_URL, USAGE_ADMIN_KEY, ADMIN_EMAIL, ADMIN_PASSWORD, VITE_ADMIN_KEY, VITE_ADMIN_EMAIL, VITE_ADMIN_PASSWORD, JWT_SECRET
